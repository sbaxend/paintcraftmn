---
import fs from "node:fs";
import path from "node:path";
import Base from "../layouts/Base.astro";
import WorkHero from "../components/our-work/WorkHero.astro";
import WorkGallery from "../components/our-work/WorkGallery.astro";
import WorkCTA from "../components/our-work/WorkCTA.astro";
import AccoladesBanner from "../components/our-work/AccoladesBanner.astro";
import Reviews from "../components/reviews/Reviews.astro";
import ReviewsTwo from "../components/reviews/ReviewsTwo.astro";

const IMAGE_EXTS = new Set([".jpg", ".jpeg", ".png", ".webp"]);
const transformationsDir = path.join(process.cwd(), "public", "Website Transformations");

const items = fs
  .readdirSync(transformationsDir)
  .sort()
  .flatMap((folder) => {
    const folderPath = path.join(transformationsDir, folder);
    if (!fs.statSync(folderPath).isDirectory()) return [];
    return fs
      .readdirSync(folderPath)
      .filter((file) => IMAGE_EXTS.has(path.extname(file).toLowerCase()))
      .sort()
      .map((file, idx) => ({
        id: `${folder.toLowerCase().replace(/\W+/g, "-")}-${idx}`,
        type: folder,
        title: folder,
        img: `/Website Transformations/${folder}/${file}`.replace(/ /g, "%20"),
      }));
  });

let reviewsData = null;
let reviewsError = false;
---

<Base title="Our Work | PaintCraft MN">
  <WorkHero
    kicker="Project Gallery"
    title="Beautiful results, crafted to last."
    subtitle="Browse our cabinet, wall, ceiling, trim, staining, and exterior work across the Twin Cities."
  />
  <AccoladesBanner />

  <!-- NEW: Filtered gallery with modal -->
  <WorkGallery items={items} />

  {!reviewsError && reviewsData ? (
  <ReviewsTwo reviews={reviewsData} />
) : (
  <Reviews />
)}

  <WorkCTA />
</Base>
