---
export type WorkItem = {
  id: string;
  type: string;
  title: string;
  img: string;
  location?: string;
  description?: string;
  tags?: string[];
};

export interface Props {
  project: WorkItem;
  typeLabel: string;
}

const { project, typeLabel } = Astro.props as Props;
const showTitle = !!(project.title && project.title.toLowerCase() !== typeLabel.toLowerCase());
---

<article
  class="work-card group cursor-pointer"
  data-project-id={project.id}
  data-type={project.type}
  data-title={project.title}
  data-img={project.img}
  data-description={project.description || ""}
  data-location={project.location || ""}
>
  <!-- Photo -->
  <div
    class="relative aspect-[4/3] rounded-2xl sm:rounded-3xl overflow-hidden bg-neutral-100 shadow-[0_8px_30px_rgba(15,23,42,0.15)] sm:shadow-[0_18px_55px_rgba(15,23,42,0.22)] transition-all duration-500 group-hover:shadow-[0_28px_80px_rgba(15,23,42,0.30)]"
  >
    <img
      src={project.img}
      alt={`${project.title} painting project in Twin Cities, MN by PaintCraft`}
      loading="lazy"
      decoding="async"
      style="image-orientation: from-image;"
      class="w-full h-full object-cover transition-transform duration-[900ms] group-hover:scale-110"
    />

    <!-- Gradient overlay — desktop only, mobile photo is clean -->
    <div
      class="absolute inset-0 hidden sm:block bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-500"
    ></div>

    <!-- Desktop content: title + arrow on hover -->
    <div class="hidden sm:flex absolute inset-0 p-6 flex-col justify-end">
      {showTitle && (
        <h3
          class="text-xl md:text-2xl font-bold text-white mb-1 translate-y-2 group-hover:translate-y-0 transition-transform duration-500"
        >
          {project.title}
        </h3>
      )}
    </div>

    <!-- Desktop badge -->
    <div
      class="hidden sm:block absolute top-5 left-5 rounded-full bg-[#C48356] px-4 py-1.5 shadow-lg transform group-hover:scale-110 transition-transform duration-500"
    >
      <span class="text-[0.65rem] md:text-xs font-bold text-white uppercase tracking-[0.16em]">
        {typeLabel}
      </span>
    </div>

    <!-- Desktop arrow -->
    <div
      class="hidden sm:flex absolute top-5 right-5 h-9 w-9 rounded-full bg-white/20 backdrop-blur-sm items-center justify-center opacity-0 group-hover:opacity-100 transform scale-75 group-hover:scale-100 transition-all duration-500"
    >
      <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14" /><path d="M13 5l7 7-7 7" />
      </svg>
    </div>
  </div>

  <!-- Mobile label: sits below the photo, no overlay needed -->
  <p class="sm:hidden mt-1.5 px-0.5 text-[0.65rem] font-semibold uppercase tracking-[0.12em] text-[#C48356] truncate">
    {typeLabel}
  </p>
</article>
