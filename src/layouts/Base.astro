---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import LogoSplash from "../components/home/LogoSplash.astro";
import "../styles/global.css";
import BannerFooter from "../components/layout/BannerFooter.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  isHome?: boolean;
}

const {
  title = "PaintCraft MN",
  description = "Professional painting services in the Twin Cities — interior, exterior, cabinet refinishing, and more. Licensed & insured with a 3-year warranty.",
  image = "/paintcraft_logo.webp",
  isHome = false,
} = Astro.props;

const siteOrigin = Astro.site?.href.replace(/\/$/, "") ?? "https://paintcraftmn.com";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image.startsWith("http") ? image : `${siteOrigin}${image}`;

const housePainterJsonLd = {
  "@context": "https://schema.org",
  "@type": "HousePainter",
  "name": "PaintCraft MN",
  "image": `${siteOrigin}/paintcraft_logo.webp`,
  "@id": siteOrigin,
  "url": siteOrigin,
  "telephone": "+1-952-697-9987",
  "priceRange": "$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1300 Landmark Trail S",
    "addressLocality": "Hopkins",
    "addressRegion": "MN",
    "postalCode": "55343",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 44.9778,
    "longitude": -93.2650
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "sameAs": ["https://instagram.com/paintcraftmn"],
  "areaServed": [
    "Minneapolis","St. Paul","Maple Grove","Plymouth","Minnetonka","Hopkins","Edina","Eden Prairie"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "23"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/paintcraft_logo.webp" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="PaintCraft MN" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- HousePainter LocalBusiness JSON-LD (home page only) -->
    {isHome && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(housePainterJsonLd)}
      />
    )}

    <!-- Nextdoor Pixel Code -->
    <script is:inline type="text/javascript">
      !function(e,n){var t,p;e.ndp||((t=e.ndp=function(){
      t.handleRequest?t.handleRequest.apply(t,arguments):t.queue.push(arguments)
      }).queue=[],t.v=1,(p=n.createElement(e="script")).async=!0,
      p.src="https://ads.nextdoor.com/public/pixel/ndp.js?id=6297f5b6-c074-4008-9abb-bf2626f5e408",
      (n=n.getElementsByTagName(e)[0]).parentNode.insertBefore(p,n))
      }(window,document);

      ndp('init','6297f5b6-c074-4008-9abb-bf2626f5e408', {});
      ndp('track','PAGE_VIEW');
    </script>

    <noscript>
      <img height="1" width="1" style="display:none"
        src="https://flask.nextdoor.com/pixel?pid=6297f5b6-c074-4008-9abb-bf2626f5e408&ev=PAGE_VIEW&noscript=1"/>
    </noscript>
    <!-- End Nextdoor Pixel Code -->
  </head>

  <body class="min-h-dvh bg-white">
    {Astro.url.pathname === "/" && (
      <LogoSplash logoSrc="/paintcraftmn-logo.png" duration={2200} fadeMs={900} />
    )}

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <BannerFooter />
  </body>
</html>
